rules_version = '2';
// MODELO DE CONTROLE DE ACESSO A ANEXOS (postura deliberada — não é um gap esquecido):
//
// Estas regras são um BACKSTOP GROSSO por papel (deny-by-default + manager/diretor).
// O ESCOPO TERRITORIAL (região/sede) NÃO é aplicado aqui, de propósito:
//   1. O token só carrega `role`/`appRole` (ver api/users.js) — não os regionIds/
//      siteIds do usuário. Casar território exigiria embutir o escopo nas custom
//      claims (risco do limite de 1 KB) + um firestore.get do ticket por acesso, e
//      migrar/re-emitir claims de todos os usuários (durante a transição, gestor sem
//      a claim nova seria BLOQUEADO até re-login — risco de travar acesso legítimo).
//   2. A leitura real do app usa a `url` GRAVADA no anexo (getDownloadURL/signed URL),
//      que ignora estas regras — então endurecê-las não muda o caminho de leitura.
//
// A autorização territorial de verdade vive na API (`canUserAccessTicket` em
// api/_lib/ticketAccess.js) e o alvo arquitetural é rotear os downloads pelo PROXY
// autenticado (api/_lib/attachmentProxy.js), que revalida o acesso por token no
// servidor. Enquanto o proxy não for adotado, um gestor consegue ler anexos de outra
// sede via SDK direto — risco conhecido e aceito como defense-in-depth documentado.
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isManager() {
      return isAuthenticated() && request.auth.token.role in ['admin', 'gestor'];
    }

    // Diretor participa do canal de mensagens (responde com anexo na OS), mas
    // não dos uploads de orçamento/contrato/pagamento (esses ficam com manager).
    function canAttachMessage() {
      return isAuthenticated() && request.auth.token.role in ['admin', 'gestor', 'diretor'];
    }

    function isValidImage() {
      return request.resource != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*')
        // SVG pode carregar script — bloqueado (risco de XSS armazenado).
        && request.resource.contentType != 'image/svg+xml';
    }

    function isValidPdf() {
      return request.resource != null
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }

    function isValidAttachmentDocument() {
      return request.resource != null
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType != 'image/svg+xml'
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
          || request.resource.contentType == 'application/msword'
          || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
          || request.resource.contentType == 'application/vnd.ms-excel'
          || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
          || request.resource.contentType == 'application/xml'
          || request.resource.contentType == 'text/xml'
          || request.resource.contentType == 'text/csv'
          || request.resource.contentType == 'text/plain'
        );
    }

    // O upload/download público não é permitido. Tudo passa por usuário logado.

    match /attachments/tickets/images/{ticketId}/{fileName=**} {
      allow read: if isManager();
      allow write: if isManager() && isValidImage();
    }

    match /attachments/tickets/pdfs/{ticketId}/{fileName=**} {
      allow read: if isManager();
      allow write: if isManager() && isValidPdf();
    }

    match /attachments/tickets/contracts/{ticketId}/{fileName=**} {
      allow read: if isManager();
      allow write: if isManager() && isValidPdf();
    }

    match /attachments/tickets/quotes/{ticketId}/{fileName=**} {
      allow read: if isManager();
      allow write: if isManager() && (isValidPdf() || isValidImage());
    }

    match /attachments/tickets/payments/{ticketId}/{fileName=**} {
      allow read: if isManager();
      allow write: if isManager() && isValidAttachmentDocument();
    }

    match /attachments/tickets/measurements/{ticketId}/{fileName=**} {
      allow read: if isManager();
      allow write: if isManager() && isValidAttachmentDocument();
    }

    match /attachments/tickets/messages/{ticketId}/{fileName=**} {
      allow read: if canAttachMessage();
      allow write: if canAttachMessage() && isValidAttachmentDocument();
    }

    match /attachments/tickets/inbound/{ticketId}/{fileName=**} {
      allow read: if isManager();
      allow write: if isManager() && isValidAttachmentDocument();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
