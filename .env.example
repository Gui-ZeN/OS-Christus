# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: URL pública do app (Vercel em produção).
APP_URL="https://os-christus.vercel.app"

# Firebase Infra Setup (scripts/infra/setup-firebase.mjs)
# Caminho local da service account JSON (não versionar)
GOOGLE_APPLICATION_CREDENTIALS=".secrets/firebase-admin.json"
# Opcional: força um projeto específico
FIREBASE_PROJECT_ID="os-christus"
# Bucket de anexos
FIREBASE_STORAGE_BUCKET="os-christus-attachments"
# Se true, cria bucket quando não existir
FIREBASE_ALLOW_BUCKET_CREATE="false"
# Região do bucket novo
FIREBASE_BUCKET_LOCATION="us-central1"
# Origens permitidas para CORS no bucket (separadas por vírgula)
FIREBASE_CORS_ORIGINS="http://localhost:3000,https://os-christus.vercel.app"
# Se true, não provisiona Storage
FIREBASE_SKIP_STORAGE="false"
# Se true, não provisiona Firestore
FIREBASE_SKIP_FIRESTORE="false"

# Signed URL helper (scripts/infra/generate-signed-url.mjs)
STORAGE_SIGN_MODE="upload"
TICKET_ID="OS-0050"
FILE_NAME="orcamento.pdf"
FILE_MIME_TYPE="application/pdf"
SIGNED_URL_EXPIRES_MIN="15"
# Opcional: path completo dentro do bucket
STORAGE_OBJECT_PATH=""

# SendGrid
SENDGRID_API_KEY="SG.xxxxx"
SENDGRID_FROM_EMAIL="no-reply@seudominio.com.br"
SENDGRID_FROM_NAME="OS Christus"
SENDGRID_TO_EMAIL_TEST="seuemail@dominio.com"
