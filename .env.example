# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: URL pública do app (Vercel em produção).
APP_URL="https://os-christus.vercel.app"

# Firebase Infra Setup
GOOGLE_APPLICATION_CREDENTIALS=".secrets/firebase-admin.json"
# Em produção (Vercel), usar JSON completo da service account
FIREBASE_SERVICE_ACCOUNT_JSON="{\"type\":\"service_account\",...}"
# Alternativa recomendada: service account em base64 (evita erro de escape no painel)
FIREBASE_SERVICE_ACCOUNT_B64=""
FIREBASE_PROJECT_ID="os-christus"
FIREBASE_STORAGE_BUCKET="os-christus-attachments"
FIREBASE_ALLOW_BUCKET_CREATE="false"
FIREBASE_BUCKET_LOCATION="us-central1"
FIREBASE_CORS_ORIGINS="http://localhost:3000,https://os-christus.vercel.app"
FIREBASE_SKIP_STORAGE="false"
FIREBASE_SKIP_FIRESTORE="false"

# Firebase Web App (Auth cliente)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID="os-christus"
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Signed URL helper
STORAGE_SIGN_MODE="upload"
TICKET_ID="OS-0050"
FILE_NAME="orcamento.pdf"
FILE_MIME_TYPE="application/pdf"
SIGNED_URL_EXPIRES_MIN="15"
STORAGE_OBJECT_PATH=""

# Provider de envio: sendgrid | gmail
EMAIL_PROVIDER="sendgrid"

# SendGrid
SENDGRID_API_KEY="SG.xxxxx"
SENDGRID_FROM_EMAIL="napa14@christus.com.br"
SENDGRID_FROM_NAME="OS-CHRISTUS"
SENDGRID_TO_EMAIL_TEST="napa14@christus.com.br"
SENDGRID_REPLY_TO_EMAIL="napa14@christus.com.br"
SENDGRID_INBOUND_SECRET="troque-este-segredo"

# Gmail API (fallback sem DNS de inbound)
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""
GMAIL_REDIRECT_URI="https://developers.google.com/oauthplayground"
GMAIL_FROM_EMAIL="napa14@christus.com.br"
GMAIL_SYNC_SECRET="troque-este-segredo"
GMAIL_PUBSUB_TOPIC_NAME="projects/os-christus/topics/os-christus-gmail"
GMAIL_PUSH_SECRET="troque-este-segredo"
