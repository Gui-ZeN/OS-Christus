    "infra:sendgrid:test": "node scripts/infra/sendgrid-test.mjs"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "busboy": "^1.6.0",
    "date-fns": "^4.1.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "uuid": "^13.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
