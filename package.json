  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "infra:firebase:setup": "node scripts/infra/setup-firebase.mjs",
    "infra:firebase:enable-apis": "node scripts/infra/enable-firebase-apis.mjs",
    "infra:storage:check": "node scripts/infra/check-storage.mjs",
